# ============================================================
# Proxied Translate API — Environment Variables
# Copy this file to .env and customize as needed
# ============================================================

# --- Server ---
PORT=3000

# CORS origin (* = allow all, or set to specific domain)
CORS_ORIGIN=*

# Logging: debug | info | warn | error
LOG_LEVEL=info

# --- Rate Limiting ---
# Max requests per IP within the window (0 = disabled)
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# --- Text Limits ---
MAX_TEXT_LENGTH=5000
MAX_BATCH_SIZE=50

# --- Proxy (OPTIONAL) ---
# Leave PROXY_URL empty to use direct connection (no proxy)
# If you're behind a firewall or need to bypass rate limits,
# configure a proxy below (e.g. BrightData, Oxylabs, etc.)
PROXY_URL=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=

# Whether to fall back to direct connection if proxy fails
# Set to "false" to disable fallback
PROXY_FALLBACK=true
